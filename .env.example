# Frontend Environment Variables (Vite - exposed to browser)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_ADMIN_UI_TOKEN=your_admin_ui_token_here

# Backend Environment Variables (Netlify Functions - server-only)
# Add these in Netlify dashboard under Site settings > Environment variables
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
ADMIN_API_TOKEN=your_admin_api_token_here

# Fattura Elettronica API Configuration
FATTURA_API_USERNAME=your_fattura_username_here
FATTURA_API_PASSWORD=your_fattura_password_here
FATTURA_API_BASE_URL=https://fattura-elettronica-api.it/ws2.0/test

# AI Document Extraction (Claude Vision)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
