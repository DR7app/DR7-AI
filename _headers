# Security headers (applied to all paths)
/*
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Referrer-Policy: strict-origin-when-cross-origin
  X-Content-Type-Options: nosniff
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co https://api.green-api.com https://xpay.nexigroup.com https://lookup.binlist.net; img-src 'self' data: blob: https://*.supabase.co; media-src 'self' blob:; frame-ancestors 'none'; base-uri 'none'

# HTML: never cache (prevents stale chunks after deploy)
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/
  Cache-Control: no-cache, no-store, must-revalidate

# Fingerprinted assets: immutable cache (hash changes per build)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
